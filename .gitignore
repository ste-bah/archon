# Archon .gitignore

# === Node.js ===
node_modules/
dist/
coverage/
*.tsbuildinfo

# === Python ===
__pycache__/
*.pyc
*.pyo
*.egg-info/

# === Environment / Secrets ===
.env
.env.local
.env.*.local

# === Runtime databases (regenerated from use, can be large) ===
.god-agent/events.db
.god-agent/events.db-shm
.god-agent/events.db-wal
.god-agent/episodes.db
.god-agent/episodes.db-shm
.god-agent/episodes.db-wal
.god-agent/desc.db
.god-agent/desc.db-shm
.god-agent/desc.db-wal
.god-agent/learning.db
.god-agent/learning.db-shm
.god-agent/learning.db-wal
.god-agent/coding-sessions/
.god-agent/checkpoints/
.god-agent/pipeline-output/
.god-agent/progress/
.god-agent/rlm-context/
.god-agent/phd-memory/
.god-agent/sdk-sessions/
.god-agent/tool-factory.log

# === AgentDB runtime (SoNA weights, trajectories — rebuilt from training) ===
.agentdb/sona/trajectories/*.bin
.agentdb/sona/sona_weights.bin
.agentdb/graphs/*.db

# === Vector databases (large binary files, regenerated by indexing) ===
vector_db_*/

# === Claude Code runtime state ===
.claude/runtime/
.claude/hooks/feedback-queue.processed.*.json
.claude/worktrees/
.claude/memory.db

# === Dynamic agent runtime (traces and versions grow from use) ===
.claude/agents/traces/
.claude/agents/versions/

# === Tool Factory (dynamic tool code, potentially untrusted) ===
.tool-factory/

# === ChromaDB / embedding vector data ===
data/chroma/

# === Serena venv (installed by setup script from PyPI, not bundled) ===
serena/.venv/

# === Personality daemon runtime ===
.persistent-memory/personality-daemon.log
.persistent-memory/personality-events.jsonl
.persistent-memory/sessions/
.run/

# === Logs and temp ===
logs/
tmp/
*.log

# === OS files ===
.DS_Store
Thumbs.db

# === Test artifacts ===
.test-*/
.coverage
.trunk/
.pipeline-state/
.pytest_cache/

# === Release tarballs (attached to GitHub releases, not committed) ===
releases/

# === Backups ===
backups/
*.backup-*
*.bak
